# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server) — use service account JSON fields or ADC on GCP
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Platform super-admins — comma-separated Firebase Auth UIDs (server-only; access to /admin)
PLATFORM_ADMIN_UIDS=

# Analytics
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# GA4 Measurement Protocol (server-side events, optional)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Resend
RESEND_API_KEY=
RESEND_FROM="CPIN <updates@yourdomain.com>"
OUTREACH_FROM_EMAIL=

# AI
OPENAI_API_KEY=
OPENAI_DISCOVERY_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Discovery providers (Phase 1 default: noop). Comma-separated registry ids.
DISCOVERY_PROVIDER_IDS=noop
# DISCOVERY_PROVIDER_EXAMPLE_API_KEY=

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_STARTER_ID=
PAYPAL_PLAN_PRO_ID=
PAYPAL_PLAN_CAPITAL_TEAM_ID=

# Rate limiting / cron (optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CRON_SECRET=
